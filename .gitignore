# NOTE: Cargo.lock IS committed — BM-Aegis is a binary app, not a library.
# This ensures reproducible builds across machines.

# Rust / Cargo
target/

# Node / Vite
node_modules/
dist/
dist-ssr/
*.local

# Tauri generated files
src-tauri/gen/
WixTools/

# OS artefacts
.DS_Store
Thumbs.db
desktop.ini

# Editor artefacts
.vscode/settings.json
.idea/
*.swp
*.swo

# BM-Aegis runtime data (never commit user data)
.bm-aegis/
userscripts/*.js
search-index/

# Env files
.env
.env.*
!.env.example
